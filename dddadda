local function startAirdropFarming()
    if States.AirdropFarming then return end
    local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    local folder = workspace:FindFirstChild("AirdropFolder")
    local drops = folder and folder:GetChildren() or {}
    if #drops == 0 then
        StarterGui:SetCore("SendNotification", { Title = "Premium Injector", Text = "❌ На карте пока нет аирдропов!", Duration = 3 })
        return
    end
    States.AirdropFarming = true
    StarterGui:SetCore("SendNotification", { Title = "Premium Injector", Text = "🚀 Начат сбор аирдропов...", Duration = 3 })
    local originalCFrame = hrp.CFrame
    task.spawn(function()
        for _, airdrop in pairs(drops) do
            local target = airdrop:IsA("BasePart") and airdrop or airdrop:FindFirstChildWhichIsA("BasePart", true)
            if target and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
                LocalPlayer.Character.HumanoidRootPart.CFrame = target.CFrame + Vector3.new(0, 3, 0)
                task.wait(0.3)
                local prompt = airdrop:FindFirstChildWhichIsA("ProximityPrompt", true)
                if prompt then
                    if fireproximityprompt then fireproximityprompt(prompt) else 
                        prompt.HoldDuration = 0; prompt:InputHoldBegin(); task.wait(0.05); prompt:InputHoldEnd() 
                    end
                end
                task.wait(0.4)
            end
        end
        if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
            LocalPlayer.Character.HumanoidRootPart.CFrame = originalCFrame
        end
        StarterGui:SetCore("SendNotification", { Title = "Premium Injector", Text = "✅ Сбор завершен!", Duration = 3 })
        States.AirdropFarming = false
    end)
end

