    Page.ScrollBarImageColor3 = Colors.AccentBlue
    Page.Visible = isFirst

    local PageLayout = Instance.new("UIListLayout", Page)
    PageLayout.SortOrder = Enum.SortOrder.LayoutOrder
    PageLayout.Padding = UDim.new(0, 10)

    local PagePadding = Instance.new("UIPadding", Page)
    PagePadding.PaddingTop = UDim.new(0, 15)
    PagePadding.PaddingLeft = UDim.new(0, 15)
    PagePadding.PaddingRight = UDim.new(0, 15)

    TabBtn.MouseButton1Click:Connect(function()
        for _, btn in pairs(TabButtons) do TweenService:Create(btn, TweenInfo.new(0.3), {TextColor3 = Colors.TextGray}):Play() end
        for _, page in pairs(Tabs) do page.Visible = false end
        
        TweenService:Create(TabBtn, TweenInfo.new(0.3), {TextColor3 = Colors.AccentYellow}):Play()
        local targetY = TabBtn.AbsolutePosition.Y - Sidebar.AbsolutePosition.Y
        TweenService:Create(TabIndicator, TweenInfo.new(0.4, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {Position = UDim2.new(0, 0, 0, targetY)}):Play()
        
        Page.Visible = true
        Page.Position = UDim2.new(0, 30, 0, 0)
        TweenService:Create(Page, TweenInfo.new(0.5, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {Position = UDim2.new(0, 0, 0, 0)}):Play()
    end)

    table.insert(TabButtons, TabBtn)
    table.insert(Tabs, Page)
    return Page
end

